# Environment configuration for 2P processing pipeline
# Copy this to .env and customize for your environment

# Image repository (for Singularity/Apptainer images)
# This is where the batch script will look for .sif files
IMAGE_REPO=${HOME}/.apptainer/images

# Optional: Lab space for archiving logs and configs
# LAB_SPACE=/path/to/lab/shared/space
# This can also be set to store images in a common location, e.g.: 
# IMAGE_REPO=$LAB_SPACE/images

# Optional: temp space for Matplotlib cache
# KEEP_MPL_CACHE=1
# MPL_CACHE_DIR=${SLURM_TMPDIR:-$SCRIPT_DIR/.matplotlib_cache}